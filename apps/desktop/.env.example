# Token de la API de AudD (reconocimiento de música).
# Regístrate en https://dashboard.audd.io/ para obtenerlo.
# Sin token, la app usa el plan anónimo (muy limitado, ~5识别/día).
AUDD_API_TOKEN="67a81a3462b130a80f8284de2b74fd4c"

# En desarrollo, la URL del dev server de Vite (lo inyecta el script dev).
# No necesitas tocarla.
VITE_DEV_SERVER_URL=http://localhost:5173

# Opcional en dev:
# ELECTRON_DISABLE_GPU=1          — ya activo en npm run dev:electron (evita errores GPU en WSL/VM)
# OPEN_DEVTOOLS=1                   — abre DevTools al arrancar (F12 también funciona)
# ELECTRON_DISABLE_SECURITY_WARNINGS=1 — ya activo en dev:electron

# SMTC (reloj maestro del reproductor del SO). Opcional: si no se setea, la app
# autodetecta native/smtc/dist/espejo-smtc.exe bajo el repo (compílalo con
# ./native/smtc/build.ps1). Solo Windows. Ver WINDOWS.md §5.
# SMTC_SIDECAR="C:\ruta\a\native\smtc\dist\espejo-smtc.exe"

# Wake word (comando SING por voz). OPT-IN: por defecto SING se lanza con
# Ctrl+Alt+S o clic en la pill. Si apuntas aquí a un ejecutable que imprima
# {"type":"wake"} por stdout al detectar la palabra (ver native/wakeword/README.md),
# la app lo lanza y dispara SING al oírla. Corre 100% local (no graba/envía audio).
# Si no se setea o el archivo no existe, el reader es no-op.
# WAKEWORD_SIDECAR="C:\ruta\a\wakeword.exe"
