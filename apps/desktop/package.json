{
  "name": "singevery-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Transparent desktop widget that recognizes music (Shazam/AudD) and shows synced karaoke lyrics with romaji — sing along without blocking your screen.",
  "author": "Gris",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node scripts/dev-electron.cjs",
    "dev:electron:win": "concurrently -k \"npm:dev:vite\" \"npm:dev:wait-electron:win\"",
    "dev:electron:nix": "concurrently -k \"npm:dev:vite\" \"npm:dev:wait-electron:nix\"",
    "dev:kill": "node scripts/kill-dev.cjs",
    "dev:reset-window": "node scripts/reset-window.cjs",
    "predev:electron:win": "node scripts/kill-dev.cjs --quiet",
    "predev:electron:nix": "node scripts/kill-dev.cjs --quiet",
    "dev:vite": "vite",
    "dev:wait-electron:nix": "npm run build:electron && wait-on tcp:5173 && cross-env NODE_ENV=development ELECTRON_DISABLE_SECURITY_WARNINGS=1 ELECTRON_DISABLE_GPU=1 electron .",
    "dev:wait-electron:win": "npm run build:electron && wait-on tcp:5173 && cross-env NODE_ENV=development ELECTRON_DISABLE_SECURITY_WARNINGS=1 electron .",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "start": "npm run build && electron .",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "package": "npm run build && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "cyrillic-to-translit-js": "^3.2.1",
    "electron-store": "^10.0.0",
    "es-hangul": "^2.3.8",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "pinyin-pro": "^3.27.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "selfsigned": "^5.5.0",
    "shazamio-core": "^1.3.1",
    "transliteration": "^2.3.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^2.1.5",
    "wait-on": "^8.0.0"
  }
}
